# ─────────────────────────────────────────────────────────────
# Bomulmoa 에이전트 앱 환경변수 (이 파일을 .env 로 복사해서 채우세요)
# ─────────────────────────────────────────────────────────────

# ── Slack ── (https://api.slack.com/apps 에서 앱 생성 후 발급)
# Socket Mode 사용 → 공개 URL 불필요
SLACK_BOT_TOKEN=xoxb-...              # OAuth & Permissions → Bot User OAuth Token
SLACK_APP_TOKEN=xapp-...             # Basic Information → App-Level Token (connections:write)
SLACK_SIGNING_SECRET=...             # Basic Information → Signing Secret

# 대상 워크스페이스(팀) ID: T0BEC62CMM3
# 실시간 변경 알림을 보낼 채널/DM ID. 아래는 원장님 DM(D...)으로 설정됨 → 알림이 DM으로 옴
# 특정 팀 채널로 보내려면 그 채널 ID(C...)로 교체
SLACK_NOTIFY_CHANNEL=D0BE97N1GH1

# ── Google Sheets ──
# 대상 스프레드시트 ID (URL의 /d/ 와 /edit 사이 문자열)
GOOGLE_SHEET_ID=1YaAZFnkjTaVmptDlc9HBZT2tkmzvircjsWw8tVB_rKM
# 서비스 계정 키 JSON 파일 경로. 이 서비스 계정 이메일을 시트에 '편집자'로 공유해야 함
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./service-account.json

# 탭 이름 (기본값 사용 권장)
SHEET_TAB_PRICES=단가표
SHEET_TAB_INTAKE=매입기록
SHEET_TAB_WORKLOG=작업로그

# ── Anthropic (AI 자연어 에이전트) ──
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-8

# ── 팀원 (Slack 사용자ID:이름:역할, 쉼표로 구분) ──
# Slack 사용자 ID는 프로필 → 더보기 → "멤버 ID 복사" 에서 확인
TEAM_MEMBERS=U000ODK:오도경:프론트,U000LDG:임동근:AI,U000LHJ:임혁진:백엔드

# 실시간 단가 변경 감지 폴링 주기(초). 0 이면 비활성화
WATCH_INTERVAL_SEC=60
